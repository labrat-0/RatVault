{
  "baseFontSize": 16,
  "baseTheme": "dark",
  "theme": "Cybertron",
  "accentColor": "#9b59b6",
  "cssTheme": "",
  "showFrontmatter": false,
  "foldHeading": true,
  "foldIndent": true,
  "attachmentFolderPath": "./assets/images",
  "newLinkFormat": "relative",
  "useMarkdownLinks": false,
  "newFileFolderPath": "Notes",
  "newFileLocation": "folder",
  "useTab": true,
  "tabSize": 2,
  "showLineNumber": true,
  "showRibbon": true,
  "showFileTree": true,
  "showProperties": false,
  "propertiesInDocument": "source",
  "userIgnoreFilters": [
    "pipeline/",
    "embedder/",
    "data/",
    "inbox/",
    "__pycache__/",
    "node_modules/",
    ".git/",
    ".venv/",
    "venv/"
  ],
  "alwaysUpdateLinks": true,
  "obsidianCatcherEnabled": false,
  "pdfExportSettings": {
    "pageSize": "Letter",
    "landscape": false,
    "margin": "0",
    "downscalePercent": 100
  },
  "translucency": false,
  "enabled": true,
  "maxExtractLen": 50000,
  "promptDelete": true,
  "alwaysShowMenuOnWindowEdge": false,
  "showUnsupportedFiles": false,
  "showInlineTitle": true,
  "autoConvertHtml": false
}
