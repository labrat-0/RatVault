# RatVault Configuration (.env)
# Copy to .env and fill in your values

# Provider and Model
RATVAULT_PROVIDER=ollama
RATVAULT_MODEL=llama3.2

# API Keys (only set for your chosen provider)
# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...

# Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434

# Output directories
# RATVAULT_OUTPUT_DIR=Notes
# RATVAULT_ASSETS_DIR=assets
